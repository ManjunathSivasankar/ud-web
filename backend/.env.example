MONGO_URI=
PORT=5000
CLIENT_URL=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# UPI Merchant details
MERCHANT_UPI_ID=
MERCHANT_NAME=UrbanDos

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
# Use app password without spaces in deployment secret manager.
SMTP_PASS=
SMTP_FROM_EMAIL=
ADMIN_EMAIL=
ADMIN_PHONE=

# Optional WhatsApp gateway
WHATSAPP_GATEWAY_URL=

# Firebase Admin (choose one approach)
# FIREBASE_SERVICE_ACCOUNT_PATH=./ServiceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_JSON={...json...}
